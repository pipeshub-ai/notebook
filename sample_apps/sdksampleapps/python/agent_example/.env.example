# PipesHub API base URL (no trailing slash). Default: https://app.pipeshub.com/api/v1
PIPESHUB_SERVER_URL=https://app.pipeshub.com/api/v1

# Option A: Use a pre-obtained JWT bearer token for all API calls.
# Get one from the PipesHub UI (e.g. account/settings) or via OAuth.
PIPESHUB_BEARER_AUTH=

# Option B: OAuth browser login (used if PIPESHUB_BEARER_AUTH is not set).
# Create an OAuth app in PipesHub and set redirect URI to http://localhost:8765/callback
PIPESHUB_OAUTH_CLIENT_ID=
PIPESHUB_OAUTH_CLIENT_SECRET=
# Optional: local port for OAuth callback (default 8765)
# PIPESHUB_OAUTH_REDIRECT_PORT=8765
